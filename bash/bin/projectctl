# ,install-commands
#   (Re)install commands
if [[ "${MSG}" == ",install-commands" ]]; then
  _SELF="$(readlink -f "${BASH_SOURCE[0]}")"
  _SELF_NAME="${_SELF##*/}"

  cd "$_BASH_BIN"

  # Remove all existing symbolic links
  rm -f ,*

  # Store the list of commands i.e. lines that look like: # ,cmd
  CMDS=$(rg -o -r '$1' -I -N '^ *# ,(\S+)' "$_SELF" | sort -u)

  # Build the commands
  while IFS= read -r cmd; do
    [[ -n "$cmd" ]] || continue
    ln -sf "$_SELF_NAME" ",$cmd"
    ok ",$cmd"
  done <<<"$CMDS"

  ok "All command symlinks are up to date"
  exit 0
fi

# ,clean
#   Clean generated files
if [[ "${MSG}" == ",clean" ]]; then
  ,frontend-clean
  ,db-clean
  ,backend-clean
  (cd "${_ROOT}" && rm -rf _*)
  ok "ROOT directory cleaned" "ROOT=$_ROOT"
  exit 0
fi

# ,list-todo
#   List todos under root
if [[ "${MSG}" == ",list-todo" ]]; then
  rg -F 'TODO' "$_ROOT"
  ok "'TODO' markers under ROOT in git tracked files have been listed" "ROOT=$_ROOT"
  exit 0
fi

# ,print-content (Directory | List(File))
#   Print the content of each file for AI consumption
if [[ "${MSG}" == ",print-content" ]]; then

  print_ai_guidance() {
    echo "Each file content is enclosed in an XML tag of the form <content path=\"PATH\">CONTENT</content>"
  }

  print_file() {
    local path="$1"
    file_check "$path"
    echo "<content path=\"$path\">"
    cat "$path"
    echo "</content>"
    echo ""
  }

  if [[ $PARAMS_LENGTH -eq 1 && -d "$1" ]]; then
    print_ai_guidance
    echo ""
    while IFS= read -r -d '' path; do
      print_file "$path"
    done < <(fd -t f --print0 . "$1")
    exit 0
  fi

  print_ai_guidance
  echo ""
  for path in "${PARAMS[@]}"; do
    print_file "$path"
  done
  exit 0
fi

# ,print-env
#   Print alphabetically sorted environment variables
if [[ "${MSG}" == ",print-env" ]]; then
  env | sort
  exit 0
fi

# ,print-help
#   Print commands and descriptions
if [[ "${MSG}" == ",print-help" ]]; then
  awk '
    /^# ([^ ]+) #$/ {
      printf "# %s ", $2
      pad = 42 - 3 - length($2)
      for (i = 0; i < pad; i++) printf "—"
      printf "\n"
    }
    /^# ,(.+)$/ {
      match($0, /^# (,.+)/, arr)
      cmd = arr[1]
      desc = ""
      next
    }
    /^#   / && cmd {
      desc = substr($0, 5)
      next
    }
    /^if \[\[/ {
      if (cmd && desc) {
        printf "  %s\t%s\n", cmd, desc
      }
      cmd = ""
      desc = ""
    }
  ' "$_SELF" | column -t -s $'\t'
  exit 0
fi

# ,print-path
#   Break $PATH to newlines for debugging
if [[ "${MSG}" == ",print-path" ]]; then
  echo "$PATH" | tr ':' '\n'
  exit 0
fi

# ,print-spec
#   Print the specification of this script
if [[ "${MSG}" == ",print-spec" ]]; then
  echo "$SPEC"
  exit 0
fi

# ,print-tree Directory
#   Print the directory tree of dir, honors .gitignore
if [[ "${MSG}" == ",print-tree" ]]; then
  dir_check "$1"
  tree --gitignore "$1"
  exit 0
fi

# ,self
#   Executing the script installs the commands and setup dependencies
if [[ "${MSG}" == "${_SELF_NAME}" ]]; then
  (cd "${_BASH_BIN}" && ln -sf "${_SELF_NAME}" ,install-commands)
  ,install-commands >/dev/null
  ,update-deps >/dev/null
  ,print-help
  exit 0
fi

# ,emacs … 
#   Start Emacs using the project's Emacs configuration directory
if [[ "${MSG}" == ",emacs" ]]; then
  emacs --init-directory="$_EMACSD" "$@"
  exit 0
fi

# ,ec …
#   Start Emacs as fast as possible for quick edits
if [[ "${MSG}" == ",ec" ]]; then
  exec emacs -Q -nw --init-directory="${_EMACSD}" "$@"
fi

# ,update-deps
#   Update dependencies not directly managed by Guix
if [[ "${MSG}" == ",update-deps" ]]; then
  backend_update
  frontend_update
  ok "Dependencies not directly managed by Guix have been updated"
  exit 0
fi

# All other cases
error "Unexpected message" "MSG=${MSG[*]}" "PARAMS=${PARAMS[*]}"
info "try: ,print-help"
exit 1
