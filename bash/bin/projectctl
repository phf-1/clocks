# ,app-deploy-dev
#   Deploy the current version to a local dev VM
if [[ "${MSG}" == ",app-deploy-dev" ]]; then
  # machine="0-init"
  # # if dev vm is not started, ask user to start it outside.
  # port="$(machine_ssh_port "$machine")"
  # info "Checking if the dev VM is running and accessible on port" "port=$port"
  # if ! machine_is_live "$machine" "2" >/dev/null; then
