#! /usr/bin/env python3.11

# Specification

# [[id:344d2579-2d67-4901-8e70-1849eea0c843][projectctl]]
#
# This executable acts as a centralized CLI for the project. It automatizes needed
# operations like starting the database, linting source files, or deploying the
# application.

# Implementation

from __future__ import annotations
import os
import re
import sys
import subprocess
from pathlib import Path

SPEC = """
What is the objective of this script?

  Its objective is to minimize the cost of executing repetitive tasks. This script
  makes this directory respond to commands, automating various tasks, like starting
  the REPL, executing tests or formatting code.

How to use this script?

  if: $ ln -s this_script a_command,
  then: $ a_command param is identical to invoking the script with <a_command, [param]>

How to choose a new command name?

  command_name :≡ "," (component "-")? verb ("-" param)*
  example :≡ ,help
  example :≡ ,backend-test

  Commands start with a comma "," so that they are easy to differentiate from
  non-project commands. For instance: ",help".

  If the command is addressed to the project itself, then it starts with a verb. For
  instance: ",help".

  If the command is addressed to a part of the project, then it starts with the name
  of that part and then a verb. For instance: ",backend-test".

  To add a new command, just look at the implementation, copy/paste the simplest one,
  start from there.

How to add a new command?

  To add a new command, just look at the implementation, copy/paste the simplest one,
  start from there.

How is this script structured?

  Assume that cmd is the name of this script, then invoking this script must be
  understood as follows:

  $ ./cmd param1 param2 :≡
    message :≡ <cmd, [param1 param2]>

    case message
      <a, []> ↦
        # do something

      <cmd, [x,y]> ↦
        # do something

      … ↦
        # do something

      _ ↦
        error "unexpected message"
"""

SELF = Path(os.path.realpath(__file__))
SELF_NAME = SELF.name

# Add python/bin/../lib sys.path
sys.path.insert(0, str(SELF.parent.parent / "lib"))

from log import Log      # noqa: E402
ok = Log.ok
info = Log.info

from check import Check         # noqa: E402
failed = Check.failed

try:
    from fs import Fs
    from scheme import scheme_root
    from bash import bash_bash_bin
    from backend import backend_update
    from frontend import frontend_update
    _LIB_LOADED = True
except ModuleNotFoundError:
    _LIB_LOADED = False

# ---------------------------------------------------------------------------
# Environment setup  (mirrors the ROOT / GUILE_LOAD_PATH block)
# ---------------------------------------------------------------------------

if _LIB_LOADED:
    ROOT = Fs.root()
    guile_load_path = os.environ.get("GUILE_LOAD_PATH", "")
    os.environ["GUILE_LOAD_PATH"] = f"{guile_load_path}:{scheme_root()}"

# Constants

ENCODING = "utf-8"
CMD_RE = re.compile(r"^# (,.+)$")

# ---------------------------------------------------------------------------
# Message dispatch
# ---------------------------------------------------------------------------

# MSG is the name under which this script was invoked (via symlink).
MSG = Path(sys.argv[0]).name
PARAMS = sys.argv[1:]

# DEVELOPMENT #

# ,help
#   Print commands and descriptions
if MSG == ",help":
    SECTION_RE  = re.compile(r"^# ([^ ]+) #$")
    DESC_RE     = re.compile(r"^#   (.+)$")
    DISPATCH_RE = re.compile(r'^if MSG ==')

    section = ""
    cmd = ""
    desc = ""

    for line in SELF.read_text(encoding=ENCODING).splitlines():
        if m := SECTION_RE.match(line):
            print(f"# {m.group(1)} #")
        elif m := CMD_RE.match(line):
            print(f"  {m.group(1)}")
        elif m := DESC_RE.match(line):
            print(f"    {m.group(1)}")
            print("")
    sys.exit(0)

# ,install-commands
#   (Re)install commands
if MSG == ",install-commands":
    bin_dir = SELF.parent
    os.chdir(bin_dir)
    for link in bin_dir.glob(",*"):
        link.unlink()
    ok(f"Old command symlinks have been removed")
    for line in SELF.read_text(encoding=ENCODING).splitlines():
        if (m := CMD_RE.match(line)):
            cmd = m.group(1)
            symlink = bin_dir / f"{cmd}"
            symlink.symlink_to(SELF_NAME)
            ok(f"{cmd}")
    ok("All command symlinks are up to date")
    sys.exit(0)

# ,update-deps
#   Update dependencies not directly managed by Guix
if MSG == ",update-deps":
    if not _LIB_LOADED:
        failed("lib not loaded")
    backend_update()
    version = frontend_update()
    ok("Dependencies not directly managed by Guix have been updated",
       f"frontend version: {version}")
    sys.exit(0)

# Executing this script directly installs commands and fetches dependencies
if MSG == SELF_NAME:
    if not _LIB_LOADED:
        failed("lib not loaded")
    install_link = Path(bash_bash_bin()) / ",install-commands"
    install_link.unlink(missing_ok=True)
    install_link.symlink_to(SELF_NAME)

    info("Install all commands")
    subprocess.run([str(SELF.parent / ",install-commands")], check=True,
                   stdout=subprocess.DEVNULL)
    ok()

    info("Fetch dependencies")
    subprocess.run([str(SELF.parent / ",update-deps")], check=True,
                   stdout=subprocess.DEVNULL)
    ok()

    info("Print ,help")
    print()
    subprocess.run([str(SELF.parent / ",help")], check=True)
    sys.exit(0)
