# ,app-deploy Machine
#   Deploy the application to the machine
if [[ "${MSG}" == ",app-deploy" ]]; then
  # dist="$(app_dist)"
  # debug "dist=$dist"

  # package="$(app_package "$dist")"
  # debug "package=$package"

  # service="$(app_service "$package")"
