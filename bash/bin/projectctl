#! /usr/bin/env bash

# Specification

# [[id:344d2579-2d67-4901-8e70-1849eea0c843]] implements [[ref:67e45c70-590e-4b86-9ebc-8410d34a6a7d][Spec]]

read -r -d '' SPEC <<EOF
What is the objective of this script?

  Its objective is to minimize the cost of executing repetitive tasks. This script
  makes this directory respond to commands, automating various tasks, like starting
  the REPL, executing tests or formatting code.

How to use this script?

  if: $ ln -s this_script a_command,
  then: $ a_command param is identical to invoking the script with <a_command, [param]>

How to choose a new command name?

  command_name :≡ "," (component "-")? verb ("-" param)*
  example :≡ ,help
  example :≡ ,backend-test

  Commands start with a comma "," so that they are easy to differentiate from
  non-project commands. For instance: ",help".

  If the command is addressed to the project itself, then it starts with a verb. For
  instance: ",help".

  If the command is addressed to a part of the project, then it starts with the name
  of that part and then a verb. For instance: ",backend-test".

  To add a new command, just look at the implementation, copy/paste the simplest one,
  start from there.

How to add a new command?

  To add a new command, just look at the implementation, copy/paste the simplest one,
  start from there.

How is this script structured?

  Assume that cmd is the name of this script, then invoking this script must be
  understood as follows:

  $ ./cmd param1 param2 :≡
    message :≡ <cmd, [param1 param2]>

    case message
      <a, []> ↦
        # do something

      <cmd, [x,y]> ↦
        # do something

      … ↦
        # do something

      _ ↦
        error "unexpected message"
EOF

# Implementation

# $VERBOSE : Boolean that defaults to false
# $VERBOSE = true ⇒ print commands before executing them
: "${VERBOSE:=false}"
[[ "${VERBOSE}" == "true" ]] && {
  export VERBOSE
  set -x
}

set -euo pipefail
IFS=$'\n\t'

SELF="$(readlink -f "${BASH_SOURCE[0]}")"
SELF_NAME="${SELF##*/}"

source "${SELF%/*}/../lib.bash"

ROOT="$(fs_root)"
GUILE_LOAD_PATH="$GUILE_LOAD_PATH:$(scheme_root)"
export GUILE_LOAD_PATH

# Interface

# MSG is the name of the script.
# Parameters are: $1, $2…
read -r MSG <<<"${0##*/}"

# DEVELOPMENT #

# ,list-todo
#   List todos
if [[ "${MSG}" == ",list-todo" ]]; then
  rg -F 'TODO' "$(fs_root)"
  ok "List TODOs"
  exit 0
fi

# Database #

# ,db-init Mode
#   Creates a directory for the DB data
if [[ "${MSG}" == ",db-init" ]]; then
  mode_check "$1"
  mode="$1"
  db_data="$(db_init "$mode")"
  ok "The PostgreSQL cluster has been initialized" "mode=$mode" "db_data=$db_data"
  exit 0
fi

# ,db-start Mode
#   Start a PostgreSQL process
if [[ "${MSG}" == ",db-start" ]]; then
  mode_check "$1"
  mode="$1"
  db_start "$mode"
  ok "The PostgreSQL instance is started"
  exit 0
fi

# ,db-clean
#   Remove PostgreSQL directories
if [[ "${MSG}" == ",db-clean" ]]; then
  db_clean
  ok "DB cleaned" "DBROOT=$DBROOT"
  exit 0
fi

# Frontend #

# ,frontend-update
#   Update the frontend to the last version
if [[ "${MSG}" == ",frontend-update" ]]; then
  version="$(frontend_update)"
  ok "The frontend has been updated" "version=$version"
  exit 0
fi

# ,frontend-clean
#   Delete built files
if [[ "${MSG}" == ",frontend-clean" ]]; then
  frontend_clean
  ok "Frontend generated files are deleted"
  exit 0
fi

# Backend #

# ,backend-update
#   Update the backend dependencies
if [[ "${MSG}" == ",backend-update" ]]; then
  backend_update
  ok "The backend dependencies have been updated"
  exit 0
fi

# ,backend-init-db Mode
#   Set up database tables
if [[ "${MSG}" == ",backend-init-db" ]]; then
  mode_check "$1"
  mode="$1"
  backend_init_db "$mode"
  ok "The database tables have been created" "mode=$mode"
  exit 0
fi

# ,backend-migrate Mode
#   Apply pending Ecto migrations to the database
if [[ "${MSG}" == ",backend-migrate" ]]; then
  mode_check "$1"
  mode="$1"
  backend_migrate "$mode"
  ok "Ecto migration has been applied to the database" "mode=$mode"
  exit 0
fi

# ,backend-dist
#   Build a backend distribution
if [[ "${MSG}" == ",backend-dist" ]]; then
  url="$(backend_mode_url "prod")"
  info "Build the frontend distribution at url" "url=$url"
  frontend_dist="$(frontend_dist "$url")"
  ok "dist=$frontend_dist"
  info "Build the backend distribution"
  dist="$(backend_dist "$frontend_dist")"
  ok "A backend distribution has been built" "dist=$dist"
  exit 0
fi

# ,backend-clean
#   Remove the Phoenix build artifacts and dependencies
if [[ "${MSG}" == ",backend-clean" ]]; then
  backend_clean
  ok "Backend directory cleaned" "PHX=$(backend_root)"
  exit 0
fi

# App #

# ,app-repl
#   Start the application and drop into iex
if [[ "${MSG}" == ",app-repl" ]]; then
  mode="dev"
  db_init "$mode"
  db_start "$mode"
  backend_init_db "$mode"
  backend_migrate "$mode"
  url="$(backend_mode_url "$mode")"
  info "Backed is listening at url" "url: $url"
  dir="$(frontend_dist "$url")"
  backend_install_frontend "$dir"
  app_repl
  exit 0
fi

# ,app-test
#   Execute tests
if [[ "${MSG}" == ",app-test" ]]; then
  ,backend-test
  ok "Tests have been executed"
  exit 0
fi

# ,app-clean
#   Delete all generated files
if [[ "${MSG}" == ",app-clean" ]]; then
  ,frontend-clean
  ,db-clean
  ,backend-clean
  (cd "${ROOT}" && rm -rf _*)
  ok "ROOT directory cleaned" "ROOT=$ROOT"
  exit 0
fi

# Elixir #

# ,ex-format
#   Format Elixir code
if [[ "${MSG}" == ",ex-format" ]]; then
  backend_format
  ok "Phoenix code has been formatted"
  exit 0
fi

# ,ex-credo
#   Evaluate Elixir code quality
if [[ "${MSG}" == ",ex-credo" ]]; then
  backend_credo
  ok "Credo analysis finished"
  exit 0
fi

# ,ex-dialyzer
#   Typecheck Elixir code
if [[ "${MSG}" == ",ex-dialyzer" ]]; then
  backend_dialyser
  ok "Dialyzer finished"
  exit 0
fi

# ,ex-security
#   Scan Elixir code for security vulnerabilities
if [[ "${MSG}" == ",ex-security" ]]; then
  backend_soblow
  ok "Sobelow security scan finished"
  exit 0
fi

# ,ex-analyse
#   Execute all static analysis tools on Elixir code
if [[ "${MSG}" == ",ex-analyse" ]]; then
  backend_analyse
  ok "Elixir code analyzed"
  exit 0
fi

# ,ex-test-by-id Id
#   Execute the specified Elixir tests
if [[ "${MSG}" == ",ex-test-by-id" && -n "${1:-}" ]]; then
  backend_test_by_id
  ok "The backend tests identified by id have been executed" "id=$1"
  exit 0
fi

# ,ex-test
#   Execute all Elixir tests
if [[ "${MSG}" == ",ex-test" ]]; then
  backend_test
  ok "Phoenix tests executed"
  exit 0
fi

# Git #

# ,git-add-commit
#   Build a commit intended to be merged into master
if [[ "${MSG}" == ",commit" ]]; then
  ,format
  ,analyze
  ,app-test
  git add .
  git commit
  exit 0
fi

# ,git-list-versions
#   List versions
if [[ "${MSG}" == ",git-list-versions" ]]; then
  git tag | rg -F v
  exit 0
fi

# ,git-add-version Version
#   Mark the current commit as a deployed version
if [[ "${MSG}" == ",git-add-version" ]]; then
  VSN="$1"
  version_check "$VSN"
  if git tag | rg -F "$VSN" &>/dev/null; then
    failed_check "VSN exists" "VSN=$VSN"
  fi
  git tag -a "$VSN"
  exit 0
fi

# DEPLOYMENT #

# Vm #

# ,vm-init-start port
#   Start a local VM listening for SSH on port to simulate a new VPS
if [[ "${MSG}" == ",vm-init-start" ]]; then
  port_check "$1"
  ssh_port="$1"
  os="init"
  os_check "$os"

  info "Build an image for os" "os=$os"
  image="$(image "$os")"
  ok "image: $(image_qcow2 $image)"

  info "Start a VM using image listening for SSH on port" "port: $ssh_port"
  vm="$(vm "$image" "$ssh_port")"
  ok "vm: $(vm_name $vm)"

  ip="$(vm_ip "$vm")"
  debug "ip: $ip"

  port="$(vm_ssh_port "$vm")"
  debug "port: $port"

  host_key="$(vm_host_key "$vm")"
  debug "host_key: $host_key"

  root_key="$(vm_root_key "$vm")"
  debug "root_key: $root_key"

  store_key="$(vm_store_key "$vm")"
  debug "store_key: $store_key"

  ok "A new local VM to test deployment (as if it was a VPS) has been built"
  # TODO(0991): build a command ,ssh-init-vm ?
  ok "An ssh connexion can be established using ip, port and user from the container"
  ok "ip: $ip, SSH port: $port, user: root"
  ok "Root key: $root_key"
  ok "The application can be deployed to the vm using ,app-deploy ip port host"
  ok "host is the host key"
  ok "Host key: $host_key"
  ok "Store key: $store_key"
  exit 0
fi

# ,vm-build Os
#   Given an OS, then build its vm
if [[ "${MSG}" == ",vm-build" ]]; then
  vm="$(vm_build "$1")"
  ok "vm for os has been built" "os=$1" "vm=$vm"
  exit 0
fi

# ,vm-list
#   List VM images
if [[ "${MSG}" == ",vm-list" ]]; then
  vm_list
  exit 0
fi

# ,vm-start Os Port
#   Given an OS and a port, start a vm that listens for ssh on port
if [[ "${MSG}" == ",vm-start" ]]; then
  os_check "$1"
  os="$1"
  port_check "$2"
  port="$2"
  vm="$(vm_build "$os")"
  vm_start "$vm" "$port"
  ok "A VM executing os has been started and is listening for ssh on port" \
    "os=$os" "vm=$os" "port=$port"
  exit 0
fi

# ,vm-init-start
#   Start s Vm that listen for SSH connections.
if [[ "${MSG}" == ",vm-init-start" ]]; then
  os="$(init_os)"
  debug "os=$os"

  image="$(image "$os")"
  debug "image=$image"

  vm_system_check
  vm="$(vm "$image")"

  ok "A Vm has been started and is listening for ssh on port" "vm=$vm" "ip=$(_vm_ip "$vm")" "port=$(_vm_port "$vm")"
  exit 0
fi

# ,vm-status Vm
#   Print the status of the executing vm, if any
if [[ "${MSG}" == ",vm-status" ]]; then
  vm_status "$1"
  exit 0
fi

# ,vm-stop Vm
#   Stop the executing vm, if any
if [[ "${MSG}" == ",vm-stop" ]]; then
  vm_stop "$1"
  exit 0
fi

# SUPPORT #

# ,print-content (Directory | List(File))
#   Print the content of each file for AI consumption
if [[ "${MSG}" == ",print-content" ]]; then

  print_ai_guidance() {
    echo "Each file content is enclosed in an XML tag of the form <content path=\"PATH\">CONTENT</content>"
  }

  print_file() {
    local path="$1"
    file_check "$path"
    echo "<content path=\"$path\">"
    cat "$path"
    echo "</content>"
    echo ""
  }

  if [[ -d "$1" ]]; then
    print_ai_guidance
    echo ""
    while IFS= read -r -d '' path; do
      print_file "$path"
    done < <(fd -t f --print0 . "$1")
    exit 0
  fi

  print_ai_guidance
  echo ""
  for path in "$@"; do
    print_file "$path"
  done
  exit 0
fi

# ,print-env
#   Print alphabetically sorted environment variables
if [[ "${MSG}" == ",print-env" ]]; then
  env | sort
  exit 0
fi

# ,path
#   Break $PATH to newlines for debugging
if [[ "${MSG}" == ",path" ]]; then
  echo "$PATH" | tr ':' '\n'
  exit 0
fi

# ,tree Directory
#   Print the directory tree of dir, honors .gitignore
if [[ "${MSG}" == ",tree" ]]; then
  dir_check "$1"
  tree --gitignore "$1"
  exit 0
fi

# ,emacs …
#   Start Emacs using the project's Emacs configuration directory
if [[ "${MSG}" == ",emacs" ]]; then
  emacs --init-directory="$_EMACSD" "$@"
  exit 0
fi

# ,ec …
#   Start Emacs as fast as possible for quick edits
if [[ "${MSG}" == ",ec" ]]; then
  exec emacs -Q -nw --init-directory="${_EMACSD}" "$@"
fi

# Bash #

# ,bash-format
#   Format bash code
if [[ "${MSG}" == ",bash-format" ]]; then
  bash_format
  ok "Bash code formatted"
  exit 0
fi

# ,bash-analyze
#   Run static analysis on Bash code
if [[ "${MSG}" == ",bash-analyze" ]]; then
  bash_analyse
  ok "Bash code analyzed"
  exit 0
fi

# Guix #

# ,guix-repl
#   Execute a Guix repl
if [[ "${MSG}" == ",guix-repl" ]]; then
  exec guix repl -i "$(scheme_root)/.guile"
fi

# ,guix-build
#   Execute a Guix build
if [[ "${MSG}" == ",guix-build" ]]; then
  exec guix build "$@"
fi

