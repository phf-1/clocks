# ,git-add-version Version
#   Mark the current commit as a deployed version
if [[ "${MSG}" == ",git-add-version" ]]; then
  VSN="$1"
  version_check "$VSN"
  if git tag | rg -F "$VSN" &>/dev/null; then
    failed_check "VSN exists" "VSN=$VSN"
  fi
  git tag -a "$VSN"
  exit 0
fi

