#! /usr/bin/env python3.11

# [[id:344d2579-2d67-4901-8e70-1849eea0c843][projectctl]]
#
# This executable acts as a centralized CLI for the project. It automatizes needed
# operations like starting the database, linting source files, or deploying the
# application.

from __future__ import annotations
import os
import re
import sys
import subprocess
import shutil
from pathlib import Path

SELF = Path(os.path.realpath(__file__))
SELF_NAME = SELF.name

lib_dir = (SELF.parent.parent / "lib").resolve()
if str(lib_dir) not in sys.path:
    sys.path.insert(0, str(lib_dir))

from log import Log      # noqa: E402
ok = Log.ok
info = Log.info
debug = Log.debug
error = Log.error
from check import Check, CheckError  # noqa: E402
failed = Check.failed
from fs import Fs        # noqa: E402
from backend import Backend  # noqa: E402
from frontend import Frontend  # noqa: E402
from db import Db              # noqa: E402
from mode import Mode    # noqa: E402
from constant import Constant    # noqa: E402
from osys import Osys      # noqa: E402
from image import Image # noqa: E402
from vm import Vm       # noqa: E402
from help import Help       # noqa: E402
from ip import Ip       # noqa: E402
from port import Port       # noqa: E402
from params import Params    # noqa: E402
from guix import Guix    # noqa: E402


ENCODING = Constant.encoding()
CMD_RE = re.compile(r" *# (,.+)$")

SPEC = """
What is the objective of this script?

  Its objective is to minimize the cost of executing repetitive tasks. This script
  makes this directory respond to commands, automating various tasks, like starting
  the REPL, executing tests or formatting code.

How to use this script?

  if: $ ln -s this_script a_command,
  then: $ a_command param is identical to invoking the script with <a_command, [param]>

How to choose a new command name?

  command_name :≡ "," (component "-")? verb ("-" param)*
  example :≡ ,help
  example :≡ ,backend-test

  Commands start with a comma "," so that they are easy to differentiate from
  non-project commands. For instance: ",help".

  If the command is addressed to the project itself, then it starts with a verb. For
  instance: ",help".

  If the command is addressed to a part of the project, then it starts with the name
  of that part and then a verb. For instance: ",backend-test".

  To add a new command, just look at the implementation, copy/paste the simplest one,
  start from there.

How to add a new command?

  To add a new command, just look at the implementation, copy/paste the simplest one,
  start from there.

How is this script structured?

  Assume that cmd is the name of this script, then invoking this script must be
  understood as follows:

  $ ./cmd param1 param2 :≡
    message :≡ <cmd, [param1 param2]>

    case message
      <a, []> ↦
        # do something

      <cmd, [x,y]> ↦
        # do something

      … ↦
        # do something

      _ ↦
        error "unexpected message"
"""

def _help():
    print(Help.string(SELF))

def _update_deps():
    Backend.update()

    version = Frontend.update()
    ok("Dependencies not directly managed by Guix have been updated",
       f"frontend version: {version}")

def _install_commands():
    bin_dir = SELF.parent
    os.chdir(bin_dir)
    for link in bin_dir.glob(",*"):
        link.unlink()
    ok("Old command symlinks have been removed")
    for line in SELF.read_text(encoding=ENCODING).splitlines():
        if (m := CMD_RE.match(line)):
            cmd = m.group(1).split(" ")[0]
            symlink = bin_dir / f"{cmd}"
            symlink.symlink_to(SELF_NAME)
            ok(f"{cmd}")
    ok("All command symlinks are up to date")

def _container_is_active():
    return "GUIX_ENVIRONMENT" in os.environ

def _dev_vm(ssh_port):
    osys = Osys("init")
    info("Build image for os", f"os: {osys}")
    image = Image(osys, inside_container=True)
    ok(f"image: {Image.qcow2(image)}")
    info("Start a VM using image listening for SSH on port", f"port: {ssh_port}")
    return Vm(image, ssh_port)

def _rcv(msg, params):
    # INSTALLATION #

    # ,install-commands
    #   (Re)install commands
    if msg == ",install-commands":
        _install_commands()
        sys.exit(0)

    # ,update-deps
    #   Update dependencies not directly managed by Guix
    if msg == ",update-deps":
        _update_deps()
        sys.exit(0)

    # Executing this script directly installs commands and fetches dependencies
    if msg == SELF_NAME:
        install_link = Path(SELF.parent) / ",install-commands"
        install_link.unlink(missing_ok=True)
        install_link.symlink_to(SELF_NAME)
        _update_deps()
        _install_commands()
        sys.exit(0)

    # DEVELOPMENT #

    # ,help
    #   Print commands and descriptions
    if msg == ",help":
        _help()
        sys.exit(0)

    # ,list-todo
    #   List todos
    if msg == ",list-todo":
        result = subprocess.run(["rg", "-F", "TODO", str(Fs.root())])
        if result.returncode not in (0, 1):
            Check.failed("rg failed", f"returncode={result.returncode}")
        ok("List TODOs")
        sys.exit(0)

    # DATABASE #

    # ,db-init (Mode :≡ dev|test|prod)
    #   Creates a directory for the DB data. 
    if msg == ",db-init":
        mode = Params.mode(params, 0)
        db_data = Db.init(mode)
        ok("The PostgreSQL cluster has been initialized",
           f"mode={mode}", f"db_data={db_data}")
        sys.exit(0)

    # ,db-start Mode
    #   Start a PostgreSQL process
    if msg == ",db-start":
        mode = Params.mode(params, 0)
        Db.start(mode)
        ok("The PostgreSQL instance is started")
        sys.exit(0)

    # ,db-status Mode
    #   Status a PostgreSQL process
    if msg == ",db-status":
        mode = Params.mode(params, 0)
        match Db.status(mode):
            case ["running", status]:
                ok(status)
            case _:
                ok(f"Database in mode {mode} is not running")
        sys.exit(0)

    # ,db-clean
    #   Remove PostgreSQL directories
    if msg == ",db-clean":
        Db.clean()
        ok("DB cleaned", f"DBROOT={Db.root()}")
        sys.exit(0)

    # FRONTEND #

    # ,frontend-update
    #   Update the frontend to the last version
    if msg == ",frontend-update":
        version = Frontend.update()
        ok("The frontend has been updated", f"version={version}")
        sys.exit(0)

    # ,frontend-clean
    #   Delete built files
    if msg == ",frontend-clean":
        Frontend.clean()
        ok("Frontend generated files are deleted")
        sys.exit(0)

    # BACKEND #

    # ,backend-update
    #   Update the backend dependencies
    if msg == ",backend-update":
        Backend.update()
        ok("The backend dependencies have been updated")
        sys.exit(0)

    # ,backend-init-db Mode
    #   Set up database tables
    if msg == ",backend-init-db":
        mode = Params.mode(params, 0)
        Backend.init_db(mode)
        ok("The database tables have been created", f"mode={mode}")
        sys.exit(0)

    # ,backend-migrate Mode
    #   Apply pending Ecto migrations to the database
    if msg == ",backend-migrate":
        mode = Params.mode(params, 0)
        Backend.migrate(mode)
        ok("Ecto migration has been applied to the database", f"mode={mode}")
        sys.exit(0)

    # ,backend-test
    #   Execute all Elixir tests
    if msg == ",backend-test":
        Backend.test()
        ok("Phoenix tests executed")
        sys.exit(0)

    # ,backend-dist
    #   Build a backend distribution
    if msg == ",backend-dist":
        url = Backend.mode_url(Mode.prod)
        info("Build the frontend distribution at url", f"url={url}")
        frontend_dist = Frontend.dist(url)
        ok("dist=", str(frontend_dist))
        info("Build the backend distribution")
        dist = Backend.dist(frontend_dist)
        ok("A backend distribution has been built", f"dist={dist}")
        sys.exit(0)

    # ,backend-clean
    #   Remove the Phoenix build artifacts and dependencies
    if msg == ",backend-clean":
        Backend.clean()
        ok("Backend directory cleaned", f"PHX={Backend.root()}")
        sys.exit(0)

    # VM #

    # ,vm-init-image-build
    #   Build the image of the init OS
    if msg == ",vm-init-image-build":
        osys = Osys("init")
        if not _container_is_active():
            error("The image should be built from within the container")
            sys.exit(1)
        image = Image(osys, inside_container=True)
        ok(f"image: {Image.qcow2(image)}")
        sys.exit(0)

    # ,vm-init-start port
    #   Start a local VM listening for SSH on port to simulate a new VPS
    if msg == ",vm-init-start":
        ssh_port = Params.port(params, 0)
        vm = _dev_vm(ssh_port)
        if _container_is_active():
            error("This command should run outside of the container")
            sys.exit(1)
        Vm.start(vm)
        ok(f"vm: {Vm.name(vm)}")
        ip = Vm.ip(vm)
        port = Vm.ssh_port(vm)
        host_key = Vm.host_key(vm)
        root_key = Vm.root_key(vm)
        store_key = Vm.store_key(vm)
        ok("A new local VM to test deployment (as if it was a VPS) has been built")
        ok("An ssh connexion can be established using ip, port and user from the container")
        ok(f"ip: {ip}, SSH port: {port}, user: root")
        ok(f"Root key: {root_key}")
        ok("The application can be deployed to the vm using ,app-deploy ip port host")
        ok("host is the host key")
        ok(f"Host key: {host_key}")
        ok(f"Store key: {store_key}")
        sys.exit(0)

    # APP #

    # ,app-repl
    #   Start the application and drop into iex
    if msg == ",app-repl":
        mode = Mode.dev
        Db.init(mode)
        Db.start(mode)
        Backend.init_db(mode)
        Backend.migrate(mode)
        url = Backend.mode_url(mode)
        frontend_dist = Frontend.dist(url)
        Backend.install_frontend(frontend_dist)
        Backend.repl()
        sys.exit(0)

    # ,app-test
    #   Execute tests
    if msg == ",app-test":
        Backend.test()
        ok("Tests have been executed")
        sys.exit(0)

    # ,app-deploy-dev port
    #   Deploy the application to the local dev VM using SSH port
    if msg == ",app-deploy-dev":
        ssh_port = Params.port(params, 0)
        vm = _dev_vm(ssh_port)
        ok(f"vm: {Vm.name(vm)}")
        ip = Vm.ip(vm)
        port = Vm.ssh_port(vm)
        if not Vm.is_running(vm, 2):
            error("Dev VM is not running.", f"ip: {ip}", f"port: {port}")
            info("Start the Dev VM outside the container with ,vm-init-start port", f"port: {port}")
            sys.exit(1)
        host_key = Vm.host_key(vm)
        result = Guix.deploy(['app', 'vm', 'init', 'machine'], [Ip.string(ip), Port.number(ssh_port), host_key])
        if result.returncode == 0:
            ok("Application has been deployed to the local vm", f"ip: {ip}", f"port: {port}", f"host_key: {host_key}")
            sys.exit(0)            
        else:
            error("Application has NOT been deployed to the local vm", f"ip: {ip}", f"port: {port}", f"host_key: {host_key}")
            sys.exit(1)            

    # ,app-clean
    #   Delete all generated files
    if msg == ",app-clean":
        Frontend.clean()
        Db.clean()
        Backend.clean()
        # Remove all top-level _* directories (exact Bash equivalent)
        root = Fs.root()
        for item in list(root.glob("_*")):
            if item.is_dir():
                shutil.rmtree(item, ignore_errors=True)
        ok("ROOT directory cleaned", f"ROOT={root}")
        sys.exit(0)

    error("Unexpected message.", f"msg: {msg}")
    sys.exit(1)

if __name__ == "__main__":
    try:
        _rcv(Path(sys.argv[0]).name, Params(sys.argv[1:]))
    except CheckError:
        sys.exit(1)
    except Exception as e:
        Log.error("Unexpected exception", str(e))
        Log.error("try: ,help")
        sys.exit(1)
