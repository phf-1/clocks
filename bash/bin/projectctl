# Interface

# bash #

# ,bash-format
#   Format bash code
if [[ "${MSG}" == ",bash-format" ]]; then
  shfmt -i 2 -w "${_BASH_FILES[@]}"
  ok "Bash code formatted"
  exit 0
fi

# ,bash-analyze
#   Run static analysis on Bash code
if [[ "${MSG}" == ",bash-analyze" ]]; then
  shellcheck -x "${_BASH_FILES[@]}"
  ok "Bash code analyzed"
  exit 0
fi

# guix #

# ,guix-repl
#   Execute a Guix repl
if [[ "${MSG}" == ",guix-repl" ]]; then
  exec guix repl -i "$_SCHEME/.guile"
fi

# db #

# ,db-init Mode
#   Creates a directory for the DB data
if [[ "${MSG}" == ",db-init" ]]; then
  MODE="${1:-dev}"
  mode_check "$MODE"
  DB_DATA="$(db_mode_to_data "$MODE")"
  if [[ ! -f "${DB_DATA}/PG_VERSION" ]]; then
    mkdir -p "${DB_DATA}"
    initdb -D "${DB_DATA}" --auth=trust --username=postgres --encoding=UTF8
  fi
  ok "The PostgreSQL cluster has been initialized" "MODE=$MODE" "DB_DATA=$DB_DATA"
  exit 0
fi

# ,db-start Mode
#   Start a PostgreSQL process
if [[ "${MSG}" == ",db-start" ]]; then
  MODE="${1:-dev}"
  mode_check "$MODE"
  ,db-init "$MODE"
  DB_DATA="$(db_mode_to_data "$MODE")"
  DB_LOG="$(db_mode_to_log "$MODE")"
  DB_PORT="$(db_port "$MODE")"
  DB_PARAMS="DB_DATA=$DB_DATA DB_LOG=$DB_LOG DB_PORT=$DB_PORT"
  if ! pg_ctl -D "${DB_DATA}" status >/dev/null 2>&1; then
    if pg_ctl -D "${DB_DATA}" -l "${DB_LOG}" -o "-p ${DB_PORT} -k /tmp" start; then
      :
    else
      error "Could not start PostgreSQL" "$DB_PARAMS"
      debug "Last 30 lines of the log:"
      tail -n 30 "${DB_LOG}" 2>/dev/null || true
      echo ""
      debug "Most common cause: stale process on port" "port=$DB_PORT"
      debug "Run this cmd once and try again" "cmd=pkill -9 -f postgres && rm -f ${DB_DATA}/postmaster.pid"
      exit 1
    fi
  fi
  ok "The PostgreSQL instance is started" "$DB_PARAMS"
  exit 0
fi

# ,db-clean
#   Remove PostgreSQL directories
if [[ "${MSG}" == ",db-clean" ]]; then
  DB_ROOT="$(db_root)"
  rm -rf "$DB_ROOT"
  ok "DB cleaned" "DB_ROOT=$DB_ROOT"
  exit 0
fi

