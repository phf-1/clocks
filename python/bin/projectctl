#! /usr/bin/env python3

import sys
import os
import subprocess
from pathlib import Path

# Allows Python to find clocks.* modules.
PATH = Path(os.path.realpath(__file__))
lib_dir = (PATH.parent.parent / "lib").resolve()
if str(lib_dir) not in sys.path:
    sys.path.append(str(lib_dir))

from clocks.params import Params  # noqa: E402
from clocks.projectctl import Projectctl  # noqa: E402
from clocks.message import Message  # noqa: E402


def start_projectctl():
    root = Path(
        subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True,
            text=True,
            check=True,
        ).stdout.strip()
    )
    bin = PATH.parent
    return Projectctl.mk(root, bin, PATH.name)


def read_msg(args):
    prop = Path(args[0]).name
    params = Params(args[1:])
    return Message.mk(prop, params)


if __name__ == "__main__":
    projectctl = start_projectctl()
    msg = read_msg(sys.argv)
    Projectctl.rcv(projectctl, msg)
    sys.exit(0)
